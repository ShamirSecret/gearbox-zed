<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>$APP_ID</id>
    <metadata_license>MIT</metadata_license>
    <project_license>Apache-2.0 and GPL-3.0-or-later</project_license>

    <name>$APP_NAME</name>
    <summary>Gearbox Chinese GUI code editor</summary>
    <developer id="dev.gearbox">
        <name translate="no">Gearbox, Inc.</name>
    </developer>
    <description>
        <p>
            Gearbox is a Chinese GUI code editor derived from an open-source editor foundation, focused on a fast local development experience.
        </p>
        <p>Features:</p>
        <ul>
            <li>Performance: Efficiently uses every CPU core and your GPU for instant startup, quick file loading, and responsive keystrokes.</li>
            <li>Language-aware: Maintains syntax trees for precise highlighting and auto-indent, with LSP support for completion and refactoring.</li>
            <li>Workflow: Project navigation, editing, terminal, search, and AI-assisted development in one local workspace.</li>
            <li>AI Integration: Supports configurable AI-assisted coding providers.</li>
        </ul>
    </description>

    <launchable type="desktop-id">$APP_ID.desktop</launchable>

    <branding>
        <color type="primary" scheme_preference="light">$BRANDING_LIGHT</color>
        <color type="primary" scheme_preference="dark">$BRANDING_DARK</color>
    </branding>

    <content_rating type="oars-1.1">
        <content_attribute id="social-chat">intense</content_attribute>
        <content_attribute id="social-audio">intense</content_attribute>
    </content_rating>

    <url type="homepage">https://github.com/ShamirSecret/gearbox-zed</url>
    <url type="bugtracker">https://github.com/ShamirSecret/gearbox-zed/issues</url>
    <url type="faq">https://github.com/ShamirSecret/gearbox-zed</url>
    <url type="help">https://github.com/ShamirSecret/gearbox-zed</url>
    <url type="contact">https://github.com/ShamirSecret/gearbox-zed/issues</url>
    <url type="vcs-browser">https://github.com/ShamirSecret/gearbox-zed</url>
    <url type="contribute">https://github.com/ShamirSecret/gearbox-zed</url>

    <supports>
        <internet>offline-only</internet>
    </supports>
    <recommends>
        <control>pointing</control>
        <control>keyboard</control>
        <display_length compare="ge">768</display_length>
    </recommends>

    <screenshots>
        <screenshot type="default">
            <caption>Gearbox with a large project open, showing language server and gitblame support</caption>
            <image>https://github.com/ShamirSecret/gearbox-zed/img/flatpak/flatpak-1.png</image>
        </screenshot>
        <screenshot>
            <caption>Gearbox with a file open and a assistant thread in the right sidebar</caption>
            <image>https://github.com/ShamirSecret/gearbox-zed/img/flatpak/flatpak-2.png</image>
        </screenshot>
        <screenshot>
            <caption>Example of a shared document</caption>
            <image>https://github.com/ShamirSecret/gearbox-zed/img/flatpak/flatpak-3.png</image>
        </screenshot>
        <screenshot>
            <caption>Gearbox's extension list</caption>
            <image>https://github.com/ShamirSecret/gearbox-zed/img/flatpak/flatpak-4.png</image>
        </screenshot>
        <screenshot>
            <caption>Theme switcher UI and example theme</caption>
            <image>https://github.com/ShamirSecret/gearbox-zed/img/flatpak/flatpak-5.png</image>
        </screenshot>
    </screenshots>

    <releases>
		@release_info@
		<release version="0.0.0" date="1970-01-01">
			<description>
				<p>Dummy release to keep flatpak-builder AppStream metadata validation from complaining</p>
			</description>
		</release>
    </releases>
</component>
