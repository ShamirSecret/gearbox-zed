name: gearbox
title: Gearbox
base: core24
version: "$RELEASE_VERSION"
summary: Gearbox Chinese GUI code editor
description: |
  Gearbox is a modern open-source code editor, built from the ground up in Rust with
  a GPU-accelerated renderer. Gearbox provides a Chinese GUI for fast local software development.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/ShamirSecret/gearbox-zed/
source-code: https://github.com/ShamirSecret/gearbox-zed
issues: https://github.com/ShamirSecret/gearbox-zed/issues
contact: https://github.com/ShamirSecret/gearbox-zed/issues

parts:
  gearbox:
    plugin: dump
    source: "https://github.com/ShamirSecret/gearbox-zed/releases/download/v$RELEASE_VERSION/gearbox-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Gearbox exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Gearbox exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  zed:
    command: usr/bin/zed
    common-id: dev.gearbox.Gearbox
    environment:
      ZED_BUNDLE_TYPE: snap
